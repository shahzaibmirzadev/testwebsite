# Copy this file to .env.local or .env and fill in the real values locally.
# Never commit real secrets.

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SerpAPI
SERPAPI_KEY=

# Optional SerpAPI timeout in milliseconds.
# SERPAPI_REQUEST_TIMEOUT_MS=12000

# Optional ATS discovery config override.
# ATS_SERP_DISCOVERY_CONFIG=

# Workable sync rate limits.
WORKABLE_MIN_REQUEST_INTERVAL_MS=
WORKABLE_COLD_START_DELAY_MS=
WORKABLE_MAX_RETRY_AFTER_MS=

# SEO feature flags.
# SEO_CONTENT_BLOCKS_V1=false
# SEO_LINKING_V1=false
