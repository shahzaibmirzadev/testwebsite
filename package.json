{
  "name": "drone-job-website",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "build:check": "next build",
    "seo:assert": "node scripts/seo-assert.mjs",
    "seo:audit": "node --env-file=.env.local --import tsx scripts/seo/auditSeo.ts",
    "sync:sources": "node scripts/sync-sources-from-master.mjs",
    "ingestion:migrate-registry": "node scripts/ingestion/migrateSourcesToProductionRegistry.mjs",
    "ingestion:import-operational": "node scripts/ingestion/importOperationalStateFromSources.mjs",
    "ingestion:export-sources": "node scripts/ingestion/exportSourcesCsvFromRegistry.mjs",
    "ingestion:audit": "node scripts/ingestion/validateIngestionBridge.mjs",
    "ingestion:approved-master": "node scripts/ingestion/buildApprovedSourcesMaster.mjs",
    "ingestion:discovery-validate": "node scripts/ingestion/validateDiscoveryLayer.mjs",
    "ingestion:discovery-smoke": "node scripts/ingestion/smokeDiscoveryLayer.mjs",
    "ingestion:check": "npm run ingestion:audit && npm run ingestion:approved-master && npm run ingestion:discovery-validate && npm run ingestion:discovery-smoke",
    "ingestion:promote": "node scripts/ingestion/promoteSource.mjs",
    "ingestion:html-recovery-staging": "node scripts/ingestion/buildHtmlRecoveryStaging.mjs",
    "ingestion:validate-ats": "node scripts/ingestion/validateAtsCandidate.mjs",
    "ingestion:validate-html": "node scripts/ingestion/validateHtmlCandidate.mjs",
    "sync:daily": "node --env-file=.env.local scripts/daily-sync.js",
    "sync:workable": "node --env-file=.env.local scripts/sync-workable.mjs",
    "ops:health": "node --env-file=.env.local scripts/ops-health-check.mjs",
    "ops:seo-validate": "node --env-file=.env.local scripts/validate-live-seo.mjs",
    "ops:check-sources": "node --env-file=.env.local scripts/check-source-schema.mjs",
    "ops:source-coverage": "node scripts/ops/sourceCoverageReport.mjs",
    "source-recovery:dry-run": "node scripts/source-recovery/promoteManualRecoverySources.mjs",
    "ingestion:promote-html-recovery": "node scripts/source-recovery/promoteHtmlRecoverySources.mjs",
    "ingestion:merge-manual-recovery-sources": "node scripts/source-recovery/mergeManualRecoveryIntoSources.mjs",
    "ingestion:merge-html-recovery-registry": "node scripts/source-recovery/mergeHtmlRecoveryIntoProductionRegistry.mjs",
    "ops:recovery-verification": "node scripts/source-recovery/recoveryLiveVerification.mjs",
    "ops:apply-site-metrics": "node --env-file=.env.local scripts/apply-site-metrics.mjs",
    "test:classification": "node --env-file=.env.local --import tsx scripts/classification-regression.mjs",
    "classification:report": "node --env-file=.env.local --import tsx scripts/classification-report.mjs",
    "resolve:careers": "node scripts/career-resolver/run.mjs",
    "routing:table": "node scripts/career-resolver/buildRoutingTable.mjs",
    "extract:ats": "node scripts/job-extraction/runAtsExtraction.mjs",
    "extract:clean": "node scripts/job-extraction/cleanExtractedJobs.mjs",
    "extract:html": "node scripts/job-extraction/runHtmlExtraction.mjs",
    "extract:html-recovery": "node scripts/job-extraction/runHtmlRecoveryExtraction.mjs",
    "filter:jobs": "node scripts/job-extraction/filterJobs.mjs",
    "jobs:prepare-db": "node scripts/job-extraction/prepareJobsForDb.mjs",
    "pipeline:analyze": "node scripts/pipeline/analyzePipeline.mjs",
    "pipeline:decision": "node scripts/pipeline/buildDecisionReport.mjs",
    "pipeline:sync-supabase": "node --env-file=.env.local scripts/pipeline/syncPipelineToSupabase.mjs",
    "pipeline:sync-html-results": "node --env-file=.env.local scripts/pipeline/syncHtmlScraperResultsToSupabase.mjs",
    "pipeline:sync-companies": "node --env-file=.env.local scripts/pipeline/syncCompanyAndJobsToSupabase.mjs",
    "pipeline:sync-import-csv": "node --env-file=.env scripts/pipeline/syncCsvImportsToSupabase.mjs",
    "pipeline:export-sql": "node scripts/pipeline/exportPipelineToSql.mjs",
    "pipeline:export-csv": "node scripts/pipeline/exportCompanyListCsv.mjs && node scripts/pipeline/exportPipelineJobsCsv.mjs",
    "db:apply-migrations": "node --env-file=.env scripts/supabase/runSqlFiles.mjs supabase/migrations/20260411000000_ingestion_pipeline_tables.sql supabase/migrations/20260412120000_company_list_and_pipeline_jobs.sql supabase/migrations/20260413140000_pipeline_deploy_tables.sql supabase/migrations/20260414120000_html_scraper_results.sql supabase/migrations/20260415120000_site_metrics_lifetime_roles.sql supabase/migrations/20260416120000_lifetime_roles_rpc_no_duplicate_trigger.sql",
    "pipeline:post-resolve": "npm run routing:table && npm run extract:ats && npm run pipeline:analyze && npm run pipeline:decision",
    "pipeline:full": "node scripts/pipeline/runFullPipeline.mjs",
    "pipeline:deploy": "node --env-file=.env.local scripts/pipeline-deploy.mjs",
    "daily:pipeline": "node --env-file=.env.local scripts/daily-pipeline.mjs",
    "data:company-descriptions": "node scripts/build-company-descriptions.mjs",
    "data:expand-enrichment": "node scripts/expand-company-enrichment.mjs",
    "report:company-logo-priority": "node scripts/company-logo-priority-report.mjs",
    "discovery:ats-serp": "node --env-file=.env.local scripts/ats-serp-discovery/runAtsSerpDiscovery.mjs",
    "discovery:ats-serp:dry": "node scripts/ats-serp-discovery/runAtsSerpDiscovery.mjs --dry-run",
    "domain-discovery:run": "node --env-file=.env.local scripts/domain-discovery/serpDomainDiscovery.mjs",
    "domain-discovery:run:raw": "node scripts/domain-discovery/serpDomainDiscovery.mjs",
    "domain-discovery:apply": "node scripts/domain-discovery/applyDomainOverrides.mjs",
    "audit:company-identity": "node scripts/company-identity-audit.mjs",
    "data:standardize-company-descriptions": "node scripts/standardize-company-descriptions-sheet.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.3",
    "@tailwindcss/postcss": "^4.2.2",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "cheerio": "^1.2.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "next": "^16.2.1",
    "postcss": "^8.5.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "pg": "^8.16.0",
    "tldts": "^7.0.28",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "xlsx": "^0.18.5"
  },
  "main": "index.js",
  "directories": {
    "doc": "docs",
    "lib": "lib"
  },
  "keywords": [],
